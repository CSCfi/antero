        ],
        "measures": [
          {
            "name": "Tutkintojen määrä, lkm",
            "expression": [
              "",
              "var lkm = SUM(Muuttujat[lkm])",
              "return IF(lkm = 0, BLANK(), IF(lkm < 5, 2.5, MROUND(lkm, 3)))"
            ],
            "formatString": "#,0"
          },
          {
            "name": "Tutkintojen määrä, ka",
            "expression": " 0.5 * [Tutkintojen määrä, lkm]",
            "formatString": "#,0.0"
          },
          {
            "name": "Tutkintojen määrä, ei aiempaa ammatillista tai korkea-asteen tutkintoa, lkm",
            "expression": [
              "",
              "CALCULATE(",
              "\t[Tutkintojen määrä, lkm], ",
              "\tFILTER(",
              "\t\tVALUES(Muuttujat[Pohjakoulutus (rahoitus)]), ",
              "\t\tMuuttujat[Pohjakoulutus (rahoitus)] = \"Ei aiempaa ammatillista tai korkea-asteen tutkintoa\"",
              "\t)",
              ")"
            ],
            "formatString": "#,0"
          },
          {
            "name": "Tutkintojen määrä, ei aiempaa ammatillista tai korkea-asteen tutkintoa, ka",
            "expression": [
              "",
              "0.5*[Tutkintojen määrä, ei aiempaa ammatillista tai korkea-asteen tutkintoa, lkm]"
            ],
            "formatString": "#,0.0"
          },
          {
            "name": "Tutkintojen painotetut pisteet, lkm",
            "expression": [
              "",
              "72*[Tutkintojen määrä, ei aiempaa ammatillista tai korkea-asteen tutkintoa, lkm]"
            ],
            "formatString": "#,0"
          },
          {
            "name": "Tutkintojen painotetut pisteet, ka",
            "expression": [
              "",
              "0.5*[Tutkintojen painotetut pisteet, lkm]"
            ],
            "formatString": "#,0.0"
          },
          {
            "name": "Keskimääräinen painotus aiemman koulutuksen mukaan",
            "expression": [
              "",
              "DIVIDE([Tutkintojen painotetut pisteet, lkm], [Tutkintojen määrä, lkm])"
            ],
            "formatString": "0.00"
          },
          {
            "name": "Tutkintojen osuus ilman aiempaa ammatillista tai korkea-asteen tutkintoa",
            "expression": [
              "",
