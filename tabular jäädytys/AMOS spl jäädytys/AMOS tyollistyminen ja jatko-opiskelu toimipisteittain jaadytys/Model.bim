        ],
        "measures": [
          {
            "name": "Koulutuksen suorittaneet",
            "expression": [
              "",
              "var lkm = SUM(Muuttujat[lkm])",
              "return IF(lkm = 0, BLANK(), IF(lkm < 5, 2.5, MROUND(lkm, 3)))"
            ],
            "formatString": "#,0"
          },
          {
            "name": "Tutkinnot yhteensä",
            "expression": [
              "",
              "CALCULATE([Koulutuksen suorittaneet], FILTER(VALUES(Muuttujat[Suorituksen tyyppi]), Muuttujat[Suorituksen tyyppi]=\"Koko tutkinto\"))"
            ],
            "formatString": "#,0",
            "isHidden": true
          },
          {
            "name": "Tutkinnon osat yhteensä",
            "expression": [
              "",
              "CALCULATE([Koulutuksen suorittaneet], FILTER(VALUES(Muuttujat[Suorituksen tyyppi]), Muuttujat[Suorituksen tyyppi]=\"Tutkinnon osa/osia\"))"
            ],
            "formatString": "#,0",
            "isHidden": true
          },
          {
            "name": "Tutkinnon suorittaneet (ei työll. ennen koul.), työllinen, ei jatko-opiskelija, lkm",
            "expression": [
              "",
              "CALCULATE(",
              "\t[Tutkinnot yhteensä]",
              "\t, FILTER(VALUES(Muuttujat[Työllinen ennen koulutusta]), Muuttujat[Työllinen ennen koulutusta]<>\"Työllinen ennen koulutuksen alkamisvuotta\")",
              "\t, FILTER(VALUES(Muuttujat[Työllinen]), Muuttujat[Työllinen]=\"Työllinen\")",
              "\t, FILTER(VALUES(Muuttujat[Korkeakouluopiskelija]), Muuttujat[Korkeakouluopiskelija]<>\"Korkeakouluopiskelija\")",
              ")"
            ],
            "formatString": "#,0"
          },
          {
            "name": "Tutkinnon suorittaneet (ei työll. ennen koul.), jatko-opiskelija, ei työllinen, lkm",
            "expression": [
              "",
              "CALCULATE(",
              "\t[Tutkinnot yhteensä]",
              "\t, FILTER(VALUES(Muuttujat[Työllinen ennen koulutusta]), Muuttujat[Työllinen ennen koulutusta]<>\"Työllinen ennen koulutuksen alkamisvuotta\")",
              "\t, FILTER(VALUES(Muuttujat[Korkeakouluopiskelija]), Muuttujat[Korkeakouluopiskelija]=\"Korkeakouluopiskelija\")",
              "\t, FILTER(VALUES(Muuttujat[Työllinen]), Muuttujat[Työllinen]<>\"Työllinen\")",
              ")"
            ],
            "formatString": "#,0"
          },
          {
