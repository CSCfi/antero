          {
            "type": "calculated",
            "name": "Tieteenalaryhmä",
            "dataType": "string",
            "expression": [
              "IF(OR([Koodit Tieteenala]=\"111\",[Koodit Tieteenala]=\"112\"),\"Matematiikka, tilastotiede\",",
              "IF(OR([Koodit Tieteenala]=\"1182\",[Koodit Tieteenala]=\"1184\"),\"Biolääketieteet, biotieteet\",",
              "IF(OR([Koodit Tieteenala]=\"3111\",[Koodit Tieteenala]=\"3112\"),\"Biolääketieteet, biotieteet\",",
              "IF(OR([Koodit Tieteenala]=\"317\",[Koodit Tieteenala]=\"318\"),\"Biolääketieteet, biotieteet\",",
              "IF(OR([Koodit Tieteenala]=\"1172\",[Koodit Tieteenala]=\"1181\"),\"Ekologia, ympäristötiede, kasvibiologia\",",
              "IF([Koodit Tieteenala]=\"1183\",\"Ekologia, ympäristötiede, kasvibiologia\",",
              "IF(OR([Koodit Tieteenala]=\"114\",[Koodit Tieteenala]=\"115\"),\"Fysiikka, geotieteet, avaruustieteet\",",
              "IF([Koodit Tieteenala]=\"1171\",\"Fysiikka, geotieteet, avaruustieteet\",",
              "IF(OR([Koodit Tieteenala]=\"611\",[Koodit Tieteenala]=\"614\"),\"Humanistiset tieteet\",",
              "IF(OR([Koodit Tieteenala]=\"615\",[Koodit Tieteenala]=\"616\"),\"Humanistiset tieteet\",",
              "IF(OR([Koodit Tieteenala]=\"113\",[Koodit Tieteenala]=\"213\"),\"ICT ja sähkötekniikka\",",
              "IF(OR([Koodit Tieteenala]=\"116\",[Koodit Tieteenala]=\"215\"),\"Kemia, teknillinen kemia\",",
              "IF([Koodit Tieteenala]=\"6121\",\"Kielitieteet\",",
              "IF(OR([Koodit Tieteenala]=\"3121\",[Koodit Tieteenala]=\"3122\"),\"Kliiniset lääketieteet\",",
              "IF(OR([Koodit Tieteenala]=\"3123\",[Koodit Tieteenala]=\"3124\"),\"Kliiniset lääketieteet\",",
              "IF(OR([Koodit Tieteenala]=\"3125\",[Koodit Tieteenala]=\"3126\"),\"Kliiniset lääketieteet\",",
              "IF(OR([Koodit Tieteenala]=\"313\",[Koodit Tieteenala]=\"319\"),\"Kliiniset lääketieteet\",",
              "IF(OR([Koodit Tieteenala]=\"515\",[Koodit Tieteenala]=\"516\"),\"Käyttäytymistieteet\",",
              "IF(OR([Koodit Tieteenala]=\"4111\",[Koodit Tieteenala]=\"4112\"),\"Maatalous- ja metsätieteet\",",
              "IF(OR([Koodit Tieteenala]=\"412\",[Koodit Tieteenala]=\"413\"),\"Maatalous- ja metsätieteet\",",
              "IF([Koodit Tieteenala]=\"415\",\"Maatalous- ja metsätieteet\",",
              "IF(OR([Koodit Tieteenala]=\"216\",[Koodit Tieteenala]=\"217\"),\"Materiaalitieteet ja -tekniikka\",",
              "IF([Koodit Tieteenala]=\"221\",\"Materiaalitieteet ja -tekniikka\",",
              "IF([Koodit Tieteenala]=\"119\",\"Muut luonnontieteet\",",
              "IF(OR([Koodit Tieteenala]=\"6122\",[Koodit Tieteenala]=\"6131\"),\"Taiteet ja kirjallisuuden tutkimus\",",
              "IF([Koodit Tieteenala]=\"6132\",\"Taiteet ja kirjallisuuden tutkimus\",",
              "IF(OR([Koodit Tieteenala]=\"511\",[Koodit Tieteenala]=\"512\"),\"Taloustieteet\",",
              "IF(OR([Koodit Tieteenala]=\"211\",[Koodit Tieteenala]=\"212\"),\"Tekniikka\",",
              "IF(OR([Koodit Tieteenala]=\"214\",[Koodit Tieteenala]=\"218\"),\"Tekniikka\",",
              "IF(OR([Koodit Tieteenala]=\"219\",[Koodit Tieteenala]=\"220\"),\"Tekniikka\",",
              "IF([Koodit Tieteenala]=\"222\",\"Tekniikka\",",
              "IF(OR([Koodit Tieteenala]=\"3141\",[Koodit Tieteenala]=\"3142\"),\"Terveystieteet\",",
              "IF(OR([Koodit Tieteenala]=\"315\",[Koodit Tieteenala]=\"316\"),\"Terveystieteet\",",
              "IF(OR([Koodit Tieteenala]=\"513\",[Koodit Tieteenala]=\"5141\"),\"Yhteiskuntatieteet\",",
              "IF(OR([Koodit Tieteenala]=\"5142\",[Koodit Tieteenala]=\"517\"),\"Yhteiskuntatieteet\",",
              "IF(OR([Koodit Tieteenala]=\"518\",[Koodit Tieteenala]=\"519\"),\"Yhteiskuntatieteet\",",
              "IF([Koodit Tieteenala]=\"520\",\"Yhteiskuntatieteet\",",
              "\"Tieto puuttuu\")))))))))))))))))))))))))))))))))))))"
            ],
            "displayFolder": "Tieteenalamuuttujat"
          },
          {
