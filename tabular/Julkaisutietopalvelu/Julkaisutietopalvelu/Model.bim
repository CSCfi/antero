        "measures": [
          {
            "name": "Julkaisut",
            "expression": "IF(sum([lukumaara])=0,BLANK(),SUM([lukumaara]))",
            "formatString": "#,0"
          },
          {
            "name": "Publikationer",
            "expression": "IF(sum([lukumaara])=0,BLANK(),SUM([lukumaara]))",
            "formatString": "#,0"
          },
          {
            "name": "Publications",
            "expression": "IF(sum([lukumaara])=0,BLANK(),SUM([lukumaara]))",
            "formatString": "#,0"
          },
          {
            "name": "Julkaisut3",
            "expression": "sum([lukumaara])"
          },
          {
            "name": "Jufot",
            "expression": "CALCULATE(AVERAGE([Jufotaso int]),FILTER(Muuttujat,OR(OR([Jufotaso int]=1,[Jufotaso int]=2),[Jufotaso int]=3)),FILTER(Muuttujat,OR([Koodit Julkaisun pääluokka]=\"A\",[Koodit Julkaisun pääluokka]=\"C\")),FILTER(Muuttujat,[Tilastovuosi]>=2015))"
          },
          {
            "name": "Jufot_2011_2014",
            "expression": "CALCULATE(AVERAGE([Jufotaso int]),FILTER(Muuttujat,OR(OR([Jufotaso int]=1,[Jufotaso int]=2),[Jufotaso int]=3)),FILTER(Muuttujat,OR([Koodit Julkaisun pääluokka]=\"A\",[Koodit Julkaisun pääluokka]=\"C\")),FILTER(Muuttujat,[Tilastovuosi]<2015))"
          },
          {
            "name": "JufoKK",
            "expression": "CONCATENATE(FORMAT([measure1]/CALCULATE([measure1],ALL(Muuttujat[Yliopisto])),\"FIXED\"),\" (\"&CALCULATE(DISTINCTCOUNT(Muuttujat[JulkaisunTunnus]),FILTER(Muuttujat,OR(OR(Muuttujat[Jufotaso int]=1,Muuttujat[Jufotaso int]=2),Muuttujat[Jufotaso int]=3)),FILTER(Muuttujat,OR(Muuttujat[Koodit Julkaisun pääluokka]=\"A\",Muuttujat[Koodit Julkaisun pääluokka]=\"C\")),FILTER(Muuttujat,[Tilastovuosi]>=2015))&\")\")",
            "formatString": "0.00"
          },
          {
            "name": "measure1",
            "expression": "AVERAGEX(DISTINCT(Muuttujat[JulkaisunTunnus]),CALCULATE(AVERAGE(Muuttujat[Jufotaso int]),FILTER(Muuttujat,OR(OR([Jufotaso int]=1,[Jufotaso int]=2),[Jufotaso int]=3)),FILTER(Muuttujat,OR([Koodit Julkaisun pääluokka]=\"A\",[Koodit Julkaisun pääluokka]=\"C\")),FILTER(Muuttujat,[Tilastovuosi]>=2015)))"
          },
          {
            "name": "measure2",
            "expression": "AVERAGEX(VALUES(Muuttujat[JulkaisunTunnus]),CALCULATE(AVERAGE(Muuttujat[Jufotaso int]),FILTER(Muuttujat,OR(OR([Jufotaso int]=1,[Jufotaso int]=2),[Jufotaso int]=3)),FILTER(Muuttujat,OR([Koodit Julkaisun pääluokka]=\"A\",[Koodit Julkaisun pääluokka]=\"C\")),FILTER(Muuttujat,[Tilastovuosi]<2015)))"
          },
          {
            "name": "apufunktio",
            "expression": "AVERAGEX(DISTINCT(Muuttujat[JulkaisunTunnus]),CALCULATE(AVERAGE(Muuttujat[Jufotaso uusi int]),FILTER(Muuttujat,OR(OR([Jufotaso uusi int]=1,[Jufotaso uusi int]=2),[Jufotaso uusi int]=3)),FILTER(Muuttujat,OR([Koodit Julkaisun pääluokka]=\"A\",[Koodit Julkaisun pääluokka]=\"C\"))))"
          },
          {
            "name": "Jufot (Suhteellinen)",
            "expression": [
              "",
              "",
              "var lasku=CONCATENATE(FORMAT([apufunktio]/CALCULATE([apufunktio],ALL(Muuttujat[Yliopisto])),\"FIXED\"),\" (\"&CALCULATE(DISTINCTCOUNT(Muuttujat[JulkaisunTunnus]),FILTER(Muuttujat,OR(OR(Muuttujat[Jufotaso uusi int]=1,Muuttujat[Jufotaso uusi int]=2),Muuttujat[Jufotaso uusi int]=3)),FILTER(Muuttujat,OR(Muuttujat[Koodit Julkaisun pääluokka]=\"A\",Muuttujat[Koodit Julkaisun pääluokka]=\"C\")))&\")\")",
              "var lasku_julk=CALCULATE(DISTINCTCOUNT(Muuttujat[JulkaisunTunnus]),FILTER(Muuttujat,OR(OR(Muuttujat[Jufotaso uusi int]=1,Muuttujat[Jufotaso uusi int]=2),Muuttujat[Jufotaso uusi int]=3)),FILTER(Muuttujat,OR(Muuttujat[Koodit Julkaisun pääluokka]=\"A\",Muuttujat[Koodit Julkaisun pääluokka]=\"C\")))",
              "",
              "return IF(AND(HASONEVALUE(Ulkoasu[Piilota boolean]),FIRSTNONBLANK(Ulkoasu[Piilota boolean],TRUE())),",
              "\tIF(lasku_julk<20,BLANK(),lasku),lasku)"
            ]
          },
          {
            "name": "Rahoitusmallipisteet",
            "expression": [
              "",
              "",
              "/*var lkm = SUMX(Muuttujat; Muuttujat[lukumaara] * Muuttujat[painokerroin_avoimuus] * Muuttujat[painokerroin_jufo] * Muuttujat[painokerroin_julkaisutyyppi])",
              "RETURN",
              "IF(lkm = 0; BLANK(); lkm)*/",
              "IF(SUMX(Muuttujat, Muuttujat[lukumaara] * Muuttujat[painokerroin_avoimuus] * Muuttujat[painokerroin_jufo] * Muuttujat[painokerroin_julkaisutyyppi]) = 0, BLANK(), SUMX(Muuttujat, Muuttujat[lukumaara] * Muuttujat[painokerroin_avoimuus] * Muuttujat[painokerroin_jufo] * Muuttujat[painokerroin_julkaisutyyppi]))"
            ],
            "formatString": "#,0.0"
          },
          {
            "name": "Jufot (Suhteellinen ilman lkm)",
            "expression": "AVERAGEX(DISTINCT(Muuttujat[JulkaisunTunnus]),CALCULATE(AVERAGE(Muuttujat[Jufotaso uusi int]),FILTER(Muuttujat,OR(OR([Jufotaso uusi int]=1,[Jufotaso uusi int]=2),[Jufotaso uusi int]=3)),FILTER(Muuttujat,OR([Koodit Julkaisun pääluokka]=\"A\",[Koodit Julkaisun pääluokka]=\"C\"))))/CALCULATE([apufunktio],ALL(Muuttujat[Yliopisto]))",
            "formatString": "0.00"
          },
          {
            "name": "Julkaisujen osuus (monitieteisyys)",
            "expression": [
              "",
              "",
              "IF(",
              "\tAND(AND(AND(",
              "\t\tNOT(ISFILTERED(Muuttujat[Päätieteenalojen lukumäärä])), ",
              "\t\tNOT(ISFILTERED(Muuttujat[Tieteenalojen lukumäärä]))),",
              "\t\tNOT(ISFILTERED(Muuttujat[Päätieteenalojen lukumäärä (tarkka)]))),",
              "\t\tNOT(ISFILTERED(Muuttujat[Tieteenalojen lukumäärä (tarkka)]))),",
              "\tBLANK(),",
              "\tDIVIDE(",
              "\t\t[Julkaisut], ",
              "\t\tCALCULATE(",
              "\t\t\t[Julkaisut], ",
              "\t\t\tALL(Muuttujat[Tieteenalojen lukumäärä (tarkka)], Muuttujat[Tieteenalojen lukumäärä], Muuttujat[tieteenala_lkm_jarj], Muuttujat[paatieteenala_lkm_jarj],Muuttujat[tieteenala_lkm_jarj2], Muuttujat[paatieteenala_lkm_jarj2], Muuttujat[Päätieteenalojen lukumäärä (tarkka)], Muuttujat[Päätieteenalojen lukumäärä]))))"
            ],
            "formatString": "0.0 %;-0.0 %;0.0 %"
          }
        ],
