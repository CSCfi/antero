        "measures": [
          {
            "name": "tutkinnon_osia",
            "expression": [
              "",
              "var lkm = CALCULATE(DISTINCTCOUNT(Muuttujat[apusarake_osasuoritus_id]), Muuttujat[apusarake_suorittanut_tutkinnon_osan] = 1)",
              "",
              "RETURN",
              "",
              "IF(AND(lkm < 5, lkm > 0), \"1-4\", MROUND(lkm,3))"
            ],
            "formatString": "#,0"
          },
          {
            "name": "tutkinnon_osia_s",
            "expression": [
              "",
              "",
              " CALCULATE(DISTINCTCOUNT(Muuttujat[apusarake_osasuoritus_id]), Muuttujat[apusarake_suorittanut_tutkinnon_osan] = 1)"
            ],
            "formatString": "#,0"
          },
          {
            "name": "suoritetut_tutkinnot",
            "expression": [
              "",
              "",
              "var lkm = CALCULATE(DISTINCTCOUNT(Muuttujat[apusarake_opiskeluoikeus_oid]), Muuttujat[apusarake_suorittanut_tutkinnon] = 1)",
              "",
              "return",
              "",
              "IF(AND(lkm <5, lkm > 0), \"1-4\", MROUND(lkm,3))"
            ],
            "formatString": "#,0"
          },
          {
            "name": "suoritetut_tutkinnot_s",
            "expression": [
              "",
              "",
              " CALCULATE(DISTINCTCOUNT(Muuttujat[apusarake_opiskeluoikeus_oid]), Muuttujat[apusarake_suorittanut_tutkinnon] = 1)"
            ],
            "formatString": "#,0"
          }
        ],
