          {
            "name": "Ei opintopaikkaa vastaanottaneiden osuus (I sykli)2",
            "expression": [
              " --too slow --added still protection just in case / jsyrjala2",
              "var taulu1 = ",
              "SUMMARIZE(",
              "\tFILTER(",
              "\t\tADDCOLUMNS(",
              "\t\t\tSUMMARIZE(FILTER(Muuttujat,Muuttujat[Tutkinnon aloitussykli hakukohde järjestys]=1 && Muuttujat[Valitut2]=1),[Henkilö OID],[Koulutuksen alkamisvuosi],[Koulutuksen alkamiskausi])",
              "\t\t\t, \"vastaanotto_kausi\",CALCULATE(MAX(Muuttujat[Paikan vastaanottaneet2]))",
              "\t\t)",
              "\t\t,[vastaanotto_kausi]=0",
              "\t)",
              "\t,[Henkilö OID]",
              ")",
              "var lkm = CALCULATE(COUNTROWS(taulu1))",
              "var osa = IF(lkm = 0, BLANK(), IF(lkm < 5, \"1-4\", MROUND(lkm, 3)))",
              "var kaikki = CALCULATE([Valitut],Muuttujat[Tutkinnon aloitussykli hakukohde järjestys]=1)",
              "",
              "return IF(osa = BLANK(), BLANK(),",
              "IF(kaikki = \"1-4\", \"25 % – 100 %\",",
              "IF(osa = \"1-4\", IF(kaikki > 8000, 0,",
              "CONCATENATE(FORMAT(1 / kaikki, \"0.0 % – \"), FORMAT(4 / kaikki, \"0.0 %\"))),",
              "osa / kaikki)))"
