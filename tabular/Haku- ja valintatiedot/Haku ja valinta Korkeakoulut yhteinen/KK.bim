            "expression": [
              "",
              "var lkm = calculate(DISTINCTCOUNT(Muuttujat[Henkilö OID]),Muuttujat[Paikan vastaanottaneet2_indikaattori]=1)",
              "return IF(lkm = 0, BLANK(), IF(lkm < 5, \"1-4\", MROUND(lkm, 3)))"
            ]
          },
          {
            "name": "Valitut_indikaattori_s",
            "expression": "CALCULATE(DISTINCTCOUNT([Henkilö OID]),Muuttujat[Valitut2_indikaattori]=1)"
          },
          {
            "name": "Paikan vastaanottaneet_indikaattori_s",
            "expression": "calculate(DISTINCTCOUNT(Muuttujat[Henkilö OID]),Muuttujat[Paikan vastaanottaneet2_indikaattori]=1)"
          }
        ],
