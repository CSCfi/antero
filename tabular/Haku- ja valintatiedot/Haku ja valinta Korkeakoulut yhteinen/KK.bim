          {
            "name": "Alin hyväksytty pistemäärä",
            "expression": [
              "",
              "var alin = CALCULATE(MIN(Muuttujat[Pisteet]),FILTER(Muuttujat,Muuttujat[Pisteet]>0 && Muuttujat[Valitut2]=1))",
              "var tyhja = \"−\"",
              "var ehto = ",
              "AND(",
              "\tOR(OR(ISFILTERED([Hakukohde]),ISFILTERED([Sökobjekt])),ISFILTERED([Applied study programme])), ",
              "\tAND(",
              "\t\tNOT(OR(OR(ISFILTERED([Valintatapajonon tyyppi]),ISFILTERED([Typ av antagningskö])),ISFILTERED([Type of admission queue])))",
              "\t\t,NOT(OR(ISFILTERED([Valintatapajonon nimi]),ISFILTERED([Namnet på antagningskö])))",
              "\t)",
              ")",
              "var valinnat = MAX(Muuttujat[Valitut2])",
              "return IF(valinnat=0,BLANK(),IF(AND(ehto=TRUE(),alin=0),tyhja,alin))"
            ],
            "formatString": "#,0.00"
          },
          {
            "name": "Ylin hyväksytty pistemäärä",
            "expression": [
              "",
              "var ylin = CALCULATE(MAX(Muuttujat[Pisteet]),FILTER(Muuttujat,Muuttujat[Pisteet]>0 && Muuttujat[Valitut2]=1))",
              "var tyhja = \"−\"",
              "var ehto = ",
              "AND(",
              "\tOR(OR(ISFILTERED([Hakukohde]),ISFILTERED([Sökobjekt])),ISFILTERED([Applied study programme])), ",
              "\tAND(",
              "\t\tNOT(OR(OR(ISFILTERED([Valintatapajonon tyyppi]),ISFILTERED([Typ av antagningskö])),ISFILTERED([Type of admission queue])))",
              "\t\t,NOT(OR(ISFILTERED([Valintatapajonon nimi]),ISFILTERED([Namnet på antagningskö])))",
              "\t)",
              ")",
              "var valinnat = MAX(Muuttujat[Valitut2])",
              "return IF(valinnat=0,BLANK(),IF(AND(ehto=TRUE(),ylin=0),tyhja,ylin))"
            ],
            "formatString": "#,0.00"
          },
