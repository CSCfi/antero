          {
            "name": "Sama korkeakoulu, sama ala; paikan vastaanottaneet",
            "expression": [
              "",
              "var osa = CALCULATE([Paikan vastaanottaneet_indikaattori],Muuttujat[Hakutoive]<>\"1\",",
              "\tMuuttujat[sama kuin 1 hakukohteen sektori]=1,",
              "\tMuuttujat[sama kuin 1 hakukohteen kk]=1,",
              "\tMuuttujat[sama kuin 1 hakukohteen koulutusala1]=1,",
              "\tMuuttujat[Tutkinnon aloitussykli hakukohde järjestys]=1,Muuttujat[Hakutapa järjestys]=1)",
              "var kaikki = CALCULATE([Paikan vastaanottaneet_indikaattori],Muuttujat[Hakutapa järjestys]=1,Muuttujat[Tutkinnon aloitussykli hakukohde järjestys]=1)",
