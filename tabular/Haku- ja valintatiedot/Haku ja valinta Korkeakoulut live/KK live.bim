        "measures": [
          {
            "name": "Kaikki hakijat",
            "expression": [
              "",
              "var lkm = CALCULATE(DISTINCTCOUNT(Muuttujat[Henkilö OID]),Muuttujat[Lukumäärä]=1)",
              "return IF(lkm = 0, BLANK(), IF(lkm < 5, \"1-4\", MROUND(lkm, 3)))"
            ],
            "formatString": "#,0"
          },
          {
            "name": "Valitut",
            "expression": "CALCULATE([Kaikki hakijat],Muuttujat[Valitut2]=1)",
            "formatString": "#,0"
          },
          {
            "name": "Paikan vastaanottaneet",
            "expression": "calculate([Kaikki hakijat],Muuttujat[Paikan vastaanottaneet2]=1)",
            "formatString": "#,0"
          },
          {
            "name": "Ensisijaiset hakijat",
            "expression": "CALCULATE([Kaikki hakijat],Muuttujat[Ensisijaiset hakijat2]=1)",
