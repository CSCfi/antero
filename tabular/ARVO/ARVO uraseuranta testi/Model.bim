        "measures": [
          {
            "name": "Vastaajamäärä",
            "expression": [
              " ",
              "",
              "var lkm = DISTINCTCOUNT(Muuttujat[vastaajaid])",
              "RETURN",
              "IF(AND(lkm < 5, lkm > 0), \"1-4\", MROUND(lkm,3))"
            ],
            "formatString": "#,0"
          },
          {
            "name": "Pisteet",
            "expression": [
              "",
              "",
              "var lkm = CALCULATE(SUMX(Muuttujat,[rahoituskysymys_paino]*[numerovalinta]))",
              "",
              "RETURN",
              "",
              "IF([Vastaajamäärä_s] < 5, BLANK(), IF(lkm = 0, BLANK(), lkm))"
            ],
            "formatString": "#,0"
          },
          {
            "name": "Vastaajamäärä_s",
            "expression": [
              " ",
              "",
              "DISTINCTCOUNT(Muuttujat[vastaajaid])",
              ""
            ],
            "formatString": "#,0"
          },
          {
            "name": "Vastausjakauma",
            "expression": [
              "",
              "var osa = [Vastaajamäärä]",
              "var kaikki = CALCULATE([Vastaajamäärä], ALL(Muuttujat[Monivalintavaihtoehto],Muuttujat[jarjestys_monivalinta]))",
              "",
              "return ",
              "IF(NOT(ISFILTERED('Muuttujat'[Monivalintavaihtoehto])),BLANK(),",
              "IF(osa = BLANK(), BLANK(),",
              "IF(kaikki = \"1-4\", \"25 % – 100 %\",",
              "IF(osa = \"1-4\", IF(kaikki > 80000, 0, CONCATENATE(FORMAT(1 / kaikki, \"0 % – \"), FORMAT(4 / kaikki, \"0 %\"))),osa / kaikki))))",
              ""
            ],
            "formatString": "0.0 %;-0.0 %;0.0 %"
          },
          {
            "name": "Keskiarvo",
            "expression": [
              "",
              "            ",
              " IF(([Vastaajamäärä_s] <5 || ISFILTERED('Muuttujat'[Monivalintavaihtoehto])),",
              "BLANK()",
              ",CALCULATE(AVERAGE([numerovalinta]),",
              "OR('Muuttujat'[vastaustyyppi]=\"arvosana6\",'Muuttujat'[vastaustyyppi]=\"arvosana\")",
              ",LEFT(Muuttujat[Monivalintavaihtoehto], 1) <> \"0\"))"
            ],
            "formatString": "0.0"
          },
          {
            "name": "Pisteet_s",
            "expression": [
              "",
              "",
              "var lkm = CALCULATE(SUMX(Muuttujat,[rahoituskysymys_paino]*[numerovalinta]))",
              "",
              "RETURN",
              "",
              "IF(lkm = 0, BLANK(), lkm)"
            ],
            "formatString": "0"
          },
          {
            "name": "Vastausjakauma_s",
            "expression": [
              "",
              "var osa = [Vastaajamäärä_s]",
              "var kaikki = CALCULATE([Vastaajamäärä_s], ALL(Muuttujat[Monivalintavaihtoehto],Muuttujat[jarjestys_monivalinta]))",
              "",
              "return ",
              "IF(NOT(ISFILTERED('Muuttujat'[Monivalintavaihtoehto])),BLANK(),",
              "osa / kaikki)",
              ""
            ],
            "formatString": "0.0 %;-0.0 %;0.0 %"
          },
          {
            "name": "Keskiarvo_s",
            "expression": [
              "",
              "            ",
              " IF((ISFILTERED('Muuttujat'[Monivalintavaihtoehto])),",
              "BLANK()",
              ",CALCULATE(AVERAGE([numerovalinta]),",
              "OR('Muuttujat'[vastaustyyppi]=\"arvosana6\",'Muuttujat'[vastaustyyppi]=\"arvosana\")",
              ",LEFT(Muuttujat[Monivalintavaihtoehto], 1) <> \"0\"))"
            ],
            "formatString": "0.0"
          },
          {
            "name": "Rahoitusmallipisteet",
            "expression": " [Pisteet]",
            "formatString": "#,0"
          }
        ],
