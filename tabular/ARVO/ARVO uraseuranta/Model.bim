        "measures": [
          {
            "name": "Vastaajamäärä",
            "expression": [
              " ",
              "",
              "var lkm = DISTINCTCOUNT(Muuttujat[vastaajaid])",
              "RETURN",
              "IF(AND(lkm < 5, lkm > 0), \"1-4\", MROUND(lkm,3))"
            ],
            "formatString": "#,0"
          },
